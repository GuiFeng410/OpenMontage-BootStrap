{
  "mcp": {
    "servers": {
      "openmontage-providers-stock": {
        "command": "python",
        "args": ["-m", "openmontage.mcp.providers_stock"],
        "cwd": "<OPENMONTAGE_REPO_ROOT>",
        "env": {
          "OPENMONTAGE_PROJECTS_DIR": "<PROJECTS_DIR>",
          "PYTHONUTF8": "1",
          "OPENMONTAGE_ALLOWED_STOCK_SOURCES": "pexels,pixabay",
          "PEXELS_API_KEY": "<OPTIONAL_FREE>",
          "PIXABAY_API_KEY": "<OPTIONAL_FREE>"
        }
      }
    }
  }
}
