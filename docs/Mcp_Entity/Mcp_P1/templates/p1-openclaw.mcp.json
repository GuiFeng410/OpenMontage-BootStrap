{
  "mcp": {
    "servers": {
      "openmontage-doctor": {
        "command": "python",
        "args": ["-m", "openmontage.mcp.doctor"],
        "cwd": "<OPENMONTAGE_REPO_ROOT>",
        "env": {
          "OPENMONTAGE_PROJECTS_DIR": "<PROJECTS_DIR>",
          "PYTHONUTF8": "1",
          "OPENMONTAGE_P1_ALLOW_WRITES": "true"
        }
      },
      "openmontage-media": {
        "command": "python",
        "args": ["-m", "openmontage.mcp.media"],
        "cwd": "<OPENMONTAGE_REPO_ROOT>",
        "env": {
          "OPENMONTAGE_PROJECTS_DIR": "<PROJECTS_DIR>",
          "PYTHONUTF8": "1",
          "PIPER_MODEL_DIR": "<PIPER_MODEL_DIR>",
          "OPENMONTAGE_PIPER_MODEL": "zh_CN-huayan-medium"
        }
      }
    }
  }
}
