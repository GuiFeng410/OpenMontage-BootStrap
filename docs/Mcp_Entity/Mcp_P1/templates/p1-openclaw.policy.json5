{
  // Merge into OpenClaw openclaw.json — P1 production Agent
  // Keep a separate default Agent without OPENMONTAGE_P1_ALLOW_WRITES (see Mcp_P0).
  tools: {
    profile: "messaging",
    allow: [
      "bundle-mcp",
      "openmontage-doctor__*",
      "openmontage-media__*"
    ],
    deny: [
      "group:runtime",
      "browser",
      "gateway"
    ],
    sandbox: {
      tools: {
        allow: [
          "bundle-mcp",
          "openmontage-doctor__*",
          "openmontage-media__*"
        ]
      }
    }
  },
  agents: {
    defaults: {
      // Prefer a dedicated production agent id in real deployments.
      sandbox: {
        mode: "all",
        workspaceAccess: "none"
      },
      skills: [
        "openmontage-router",
        "openmontage-gates-intro",
        "openmontage-animated-explainer",
        "openmontage-production-contract",
        "openmontage-l3-remotion",
        "openmontage-l3-tts",
        "openmontage-l3-ffmpeg"
      ]
    }
  },
  skills: {
    load: {
      extraDirs: [
        "<OPENMONTAGE_REPO_ROOT>/openmontage/skills"
      ],
      watch: true
    },
    entries: {
      "openmontage-router": { enabled: true },
      "openmontage-gates-intro": { enabled: true },
      "openmontage-animated-explainer": { enabled: true },
      "openmontage-production-contract": { enabled: true },
      "openmontage-l3-remotion": { enabled: true },
      "openmontage-l3-tts": { enabled: true },
      "openmontage-l3-ffmpeg": { enabled: true }
    }
  }
}
