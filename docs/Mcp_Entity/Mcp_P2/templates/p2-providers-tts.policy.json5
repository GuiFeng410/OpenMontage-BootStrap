{
  // Merge into Production Agent openclaw.json — P2 advanced TTS only
  tools: {
    allow: [
      "bundle-mcp",
      "openmontage-doctor__*",
      "openmontage-media__*",
      "openmontage-providers-tts__*"
    ],
    sandbox: {
      tools: {
        allow: [
          "bundle-mcp",
          "openmontage-doctor__*",
          "openmontage-media__*",
          "openmontage-providers-tts__*"
        ]
      }
    }
  },
  agents: {
    defaults: {
      skills: [
        "openmontage-animated-explainer",
        "openmontage-production-contract",
        "openmontage-providers-tts"
      ]
    }
  },
  skills: {
    entries: {
      "openmontage-providers-tts": { enabled: true }
    }
  }
}
